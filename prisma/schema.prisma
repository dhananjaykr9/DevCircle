// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// User & Auth
model User {
  id          String   @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  hashedPassword String? // Added for custom credentials auth
  onboarded     Boolean   @default(false)
  role          String    @default("MEMBER") // MEMBER, MODERATOR, ADMIN
  reputation    Int       @default(0) // Used for auto-moderation 
  
  // Profile info
  bio           String?
  cityId        String?
  company       String?
  jobTitle      String?
  yearsOfExp    Int?
  experienceLevel String?
  skills        String?   // comma-separated
  interests     String?   // comma-separated
  github        String?
  linkedin      String?
  portfolioUrl  String?
  openToMentoring Boolean @default(false)
  openToCollaborate Boolean @default(false)
  
  // Relations
  city          City?     @relation(fields: [cityId], references: [id])
  posts         Post[]
  projects      Project[]
  events        Event[]   @relation("EventOrganizer")
  rsvps         Rsvp[]
  comments      Comment[]
  upvotes       Upvote[]
  jobs          Job[]
  polls         Poll[]
  pollVotes     PollVote[]
  userBadges    UserBadge[]
  menteeRequests MentorRequest[] @relation("MenteeRequests")
  mentorRequests MentorRequest[] @relation("MentorRequests")
  conversations1 Conversation[] @relation("User1Conv")
  conversations2 Conversation[] @relation("User2Conv")
  messages      Message[]
  
  proposals     Proposal[]
  proposalVotes ProposalVote[]
  reports       Report[]
  resources     Resource[]
  notifications Notification[]

  accounts      Account[]
  sessions      Session[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                 String  @id @default(uuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  
  access_token       String?  
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Communities
model City {
  id          String   @id @default(uuid())
  name        String   @unique
  state       String
  tier        String   // Tier-1, Tier-2, Tier-3
  tags        String   // comma-separated
  isActive    Boolean  @default(false)
  image       String?
  
  // Relations
  members     User[]
  posts       Post[]
  projects    Project[]
  events      Event[]
  jobs        Job[]
  polls       Poll[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Discussions Forum
model Post {
  id          String    @id @default(uuid())
  title       String
  content     String
  preview     String?
  category    String    // AI/ML, Cloud, Web Dev, etc.
  postType    String    @default("Discussion") // Discussion, Blog, Tutorial, Resource
  tags        String?   // comma-separated
  isPinned    Boolean   @default(false)
  
  // Relations
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  cityId      String
  city        City      @relation(fields: [cityId], references: [id])
  comments    Comment[]
  upvotes     Upvote[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Comment {
  id          String   @id @default(uuid())
  content     String
  
  // Relations
  postId      String
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Upvote {
  id          String   @id @default(uuid())
  
  // Relations
  postId      String
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())

  @@unique([postId, userId])
}

// Project Marketplace
model Project {
  id          String   @id @default(uuid())
  title       String
  description String
  type        String   // Optional: Hackathon, Startup, Open Source, etc.
  status      String   @default("Recruiting") // Recruiting, In Progress, Completed
  techStack   String   // Comma-separated
  lookingFor  String   // Comma-separated roles (e.g. Backend Dev, Designer)
  teamSize    Int      @default(1)
  repositoryUrl String? // Link to GitHub/GitLab repo for Open Source projects
  
  // Relations
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  cityId      String
  city        City     @relation(fields: [cityId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Events & Meetups
model Event {
  id          String   @id @default(uuid())
  title       String
  description String
  type        String   // Hack Night, Workshop, Talk, Panel
  date        DateTime
  time        String
  venue       String
  capacity    Int
  fee         String   @default("Free")
  
  // Relations
  organizerId String
  organizer   User     @relation("EventOrganizer", fields: [organizerId], references: [id])
  cityId      String
  city        City     @relation(fields: [cityId], references: [id])
  rsvps       Rsvp[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Rsvp {
  id          String   @id @default(uuid())
  
  // Relations
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())

  @@unique([eventId, userId])
}

// Job & Opportunity Board
model Job {
  id          String   @id @default(uuid())
  title       String
  company     String
  description String
  type        String   // Full-time, Internship, Freelance, Contract
  techStack   String   // comma-separated
  experience  String   // Fresher, Junior, Mid-Level, Senior
  applyUrl    String?
  salary      String?  // e.g. "₹8–12 LPA" or "Negotiable"
  isRemote    Boolean  @default(false)

  // Relations
  posterId    String
  poster      User     @relation(fields: [posterId], references: [id])
  cityId      String
  city        City     @relation(fields: [cityId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Community Polls
model Poll {
  id          String       @id @default(uuid())
  question    String
  description String?
  endsAt      DateTime?

  // Relations
  authorId    String
  author      User         @relation(fields: [authorId], references: [id])
  cityId      String
  city        City         @relation(fields: [cityId], references: [id])
  options     PollOption[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PollOption {
  id      String     @id @default(uuid())
  text    String
  pollId  String
  poll    Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes   PollVote[]
}

model PollVote {
  id           String     @id @default(uuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  pollOptionId String
  pollOption   PollOption @relation(fields: [pollOptionId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())

  @@unique([userId, pollOptionId])
}

// Contributor Badges
model Badge {
  id          String      @id @default(uuid())
  slug        String      @unique  // e.g. "first-post", "mentor", "top-contributor"
  name        String               // Display name
  description String
  icon        String               // emoji or icon name
  category    String               // Community, Mentorship, Content, Event

  userBadges  UserBadge[]
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String
  badgeId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  awardedAt DateTime @default(now())

  @@unique([userId, badgeId])
}

// Mentorship Program
model MentorRequest {
  id          String   @id @default(uuid())
  status      String   @default("PENDING") // PENDING, ACCEPTED, DECLINED
  area        String   // backend, cloud, ai-ml, career
  message     String

  menteeId    String
  mentee      User     @relation("MenteeRequests", fields: [menteeId], references: [id])
  mentorId    String
  mentor      User     @relation("MentorRequests", fields: [mentorId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Direct Messaging
model Conversation {
  id        String   @id @default(uuid())
  user1Id   String
  user1     User     @relation("User1Conv", fields: [user1Id], references: [id], onDelete: Cascade)
  user2Id   String
  user2     User     @relation("User2Conv", fields: [user2Id], references: [id], onDelete: Cascade)
  
  messages  Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // Updated when a new message arrives

  @@unique([user1Id, user2Id]) // A unique conversation exists between two specific users
}

model Message {
  id             String       @id @default(uuid())
  text           String
  isRead         Boolean      @default(false)
  
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now())
}

// Governance
model Proposal {
  id          String   @id @default(uuid())
  title       String
  description String
  status      String   @default("Active") // Active, Passed, Rejected

  // Relations
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  votes       ProposalVote[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProposalVote {
  id          String   @id @default(uuid())
  vote        String   // "Yes" or "No"
  
  // Relations
  proposalId  String
  proposal    Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([proposalId, userId])
}

model Report {
  id          String   @id @default(uuid())
  reason      String
  status      String   @default("Pending") // Pending, Reviewed, Dismissed
  
  // What was reported
  targetType  String   // e.g., "Post", "Comment", "User"
  targetId    String
  targetUrl   String?
  
  // Relations
  reporterId  String
  reporter    User     @relation(fields: [reporterId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Learning Resources
model Resource {
  id          String   @id @default(uuid())
  title       String
  description String
  url         String
  category    String   // Courses, Tutorials, Documentation, Tools
  techStack   String   // Comma-separated tags e.g. React, Node.js

  // Relations
  submitterId String
  submitter   User     @relation(fields: [submitterId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  type      String   // MESSAGE, REPLY, EVENT, MENTORSHIP
  content   String
  isRead    Boolean  @default(false)
  link      String?  // URL to redirect on click
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
}
